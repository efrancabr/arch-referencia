        <mxCell id="VWnVr7w13OXqzlNvyO-k-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Detalhes&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;A várias pipelines clássicas no devops antigo;&lt;/li&gt;&lt;li&gt;Para cada cluster é uma pipeline e estrutura distinta;&lt;/li&gt;&lt;li&gt;Pipeline acessa a base do security para obter as apikeys;&lt;/li&gt;&lt;li&gt;Os pods são reiniciados para atualizar a variável de ambiente chamada&amp;nbsp;APIKEYAUTHORIZATIONLIST;&lt;/li&gt;&lt;li&gt;Fluxo de pipelines complexos e de difícil manutenção;&lt;/li&gt;&lt;li&gt;Pipelines devem ser migradas para finalizar o devops antigo.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="230" width="310" x="-723" y="-420" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
